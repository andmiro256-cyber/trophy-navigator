{
  "productName": "Trophy Navigator Desktop",
  "version": "0.5.7",
  "identifier": "ru.trophy-nav.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Trophy Navigator Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost https://api.github.com",
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "blob:",
          "data:",
          "https://*.tile.openstreetmap.org",
          "https://*.tile.opentopomap.org",
          "https://mt0.google.com",
          "https://mt1.google.com",
          "https://mt2.google.com",
          "https://mt3.google.com",
          "https://server.arcgisonline.com",
          "https://tiles.nakarte.me",
          "https://*.tiles.nakarte.me",
          "https://tile.waymarkedtrails.org",
          "https://*.maps.yandex.net",
          "https://core-renderer-tiles.maps.yandex.net",
          "https://core-sat.maps.yandex.net",
          "https://tile2.maps.2gis.com"
        ],
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgNUQ3NTQ1MEU4REVDRjcxClJXUnh6OTdvVUZUWEJmSkliYmhUa094TnlOSEZvQW9BbnhzeVpXM2d2cWZLWCtDaDhNcmo2Y0R2Cg==",
      "endpoints": [
        "https://github.com/andmiro256-cyber/trophy-navigator/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
